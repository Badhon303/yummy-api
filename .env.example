# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/yummy-bakery

# Payload
PAYLOAD_SECRET=YOUR_SECRET_HERE
PAYLOAD_URL=http://localhost:3001

# Frontend
FRONTEND_URL=http://localhost:3000
REVALIDATION_SECRET=your-revalidation-secret

# Redis
REDIS_URL=redis://localhost:6379

# Email (Resend)
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=orders@yummybakery.com

# bKash
BKASH_SANDBOX=true
BKASH_APP_KEY=your-app-key
BKASH_APP_SECRET=your-app-secret
BKASH_USERNAME=your-username
BKASH_PASSWORD=your-password

# Nagad
NAGAD_SANDBOX=true
NAGAD_MERCHANT_ID=your-merchant-id
NAGAD_MERCHANT_NUMBER=your-merchant-number
NAGAD_PG_PUBLIC_KEY=your-base64-public-key
NAGAD_MERCHANT_PRIVATE_KEY=your-base64-private-key

# SSLCommerz
SSLCOMMERZ_LIVE=false
SSLCOMMERZ_STORE_ID=your-store-id
SSLCOMMERZ_STORE_PASSWORD=your-store-password
